# Bootpay 환경 기본값 (committed — single source of truth)
#
# 로컬 dev 테스트 시:
#   BOOTPAY_ENV=production → BOOTPAY_ENV=development 한 줄만 변경.
# 이 파일은 production 으로 유지 — 토글 변경은 커밋하지 말 것.
# 개인 키 override 가 필요하면 local.properties 를 사용 (gitignored).

BOOTPAY_ENV=production

# PG API
