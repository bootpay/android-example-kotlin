# Bootpay 환경 설정 (예시)
#
# 사용법:
#   1. 이 파일을 `.env` 또는 `local.properties`로 복사 (이미 있으면 아래 키들만 추가)
#   2. 필요한 키만 주석 해제 + 값 채우기
#   3. 미설정 키는 production 기본값(BootpayConfig.kt 빌드 결과)으로 자동 fallback
#
# 배포 기본값은 항상 production. local.properties는 .gitignore 처리됨.

# 환경 스위치 (development | production)
BOOTPAY_ENV=production

# PG API - Client Key (권장)
# BOOTPAY_CLIENT_KEY_DEV=K1Xok7RzFxbT7zMBmiBXNw
# BOOTPAY_CLIENT_KEY_PROD=OdKci2s0ux9iyFWsgYHdKw
#
# 주의: server_key (secret) 는 클라이언트에 절대 포함하지 말 것 — 서버 SDK 에서만 사용

# PG API - Application ID (legacy 호환)
# BOOTPAY_ANDROID_APPLICATION_ID_DEV=5b9f51264457636ab9a07cdc
# BOOTPAY_ANDROID_APPLICATION_ID_PROD=5b8f6a4d396fa665fdc2b5e8

# PG API - REST (legacy 호환, deprecated)
# BOOTPAY_REST_APPLICATION_ID_DEV=59b731f084382614ebf72215
# BOOTPAY_REST_APPLICATION_ID_PROD=5b8f6a4d396fa665fdc2b5ea
# BOOTPAY_PRIVATE_KEY_DEV=WwDv0UjfwFa04wYG0LJZZv1xwraQnlhnHE375n52X0U=
# BOOTPAY_PRIVATE_KEY_PROD=rm6EYECr6aroQVG2ntW0A6LpWnkTgP4uQ3H18sDDUYw=
